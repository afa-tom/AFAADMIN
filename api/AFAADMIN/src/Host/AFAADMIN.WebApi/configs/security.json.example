{
  "Security": {
    "Jwt": {
      "Issuer": "AFAADMIN",
      "Audience": "AFAADMIN-Client",
      "SecretKey": "替换为你自己的密钥至少32位字符",
      "AccessTokenExpireMinutes": 120,
      "RefreshTokenExpireDays": 7
    },
    "Encryption": {
      "EnableGlobalEncryption": false,
      "SM4Key": "替换为你自己的SM4密钥32位Hex",
      "SM3Salt": "替换为你自己的盐值"
    },
    "RateLimiting": {
      "EnableRateLimiting": true,
      "PermitLimit": 100,
      "WindowSeconds": 60,
      "LoginPermitLimit": 5,
      "LoginWindowSeconds": 60
    }
  }
}
